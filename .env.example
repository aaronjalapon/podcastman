# =============================================================================
# podcastman — Environment Configuration
# =============================================================================

# LLM Configuration (via LiteLLM)
# Supported: gpt-4o, claude-sonnet-4-20250514, ollama/llama3, etc.
LLM_MODEL=gpt-4o
LLM_API_KEY=

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb

# Google Cloud TTS
GOOGLE_TTS_VOICE_A=en-US-Standard-J
GOOGLE_TTS_VOICE_B=en-US-Standard-H
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_APPLICATION_CREDENTIALS=

# Audio
OUTPUT_DIR=./output
INTRO_AUDIO=
OUTRO_AUDIO=
PAUSE_BETWEEN_SPEAKERS_MS=400

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Frontend -> Backend (optional)
# For local Streamlit usage, defaults to http://localhost:8000 if unset.
PODCASTMAN_API_BASE=
